project_name = "hospital"
environment  = "dev"
owner        = "devops"
aws_region   = "us-east-1"

# Keep the Kubernetes API private by default.
endpoint_public_access = false
# If you enable public access, set this to your public IP, for example ["203.0.113.10/32"].
public_access_cidrs = []

single_nat_gateway = true

